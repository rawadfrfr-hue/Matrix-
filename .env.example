# Server Port (Railway will automatically set this to 3000 or allocate a port)
PORT=3000

# Firebase Client & Admin Configuration
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_DATABASE_URL=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Optional AI Studio / Gemini Credentials
GEMINI_API_KEY=
APP_URL=

# Backblaze B2 Multi-Account Configuration
# Must be a valid JSON array of objects with keys: email, bucket, keyId, appKey, endpoint, region
B2_ACCOUNTS_JSON=

# Cloudflare R2 Multi-Account Configuration
# Must be a valid JSON array of objects with keys: email, bucket, keyId, appKey, endpoint, region
R2_ACCOUNTS_JSON=

# MEGA Multi-Account Configuration
# Must be a valid JSON array of objects with keys: email, bucket, keyId, appKey, endpoint, region
MEGA_ACCOUNTS_JSON=

# Dynamic Storage Quota Configuration (in Gigabytes, defaults to 15 if not set)
STORAGE_QUOTA_GB=15
