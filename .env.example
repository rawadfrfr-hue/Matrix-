# Server Port (Railway will automatically set this to 3000 or allocate a port)
PORT=3000

# Matrix Homeserver & API Credentials
MATRIX_HOMESERVER=https://matrix.org
MATRIX_USERNAME=
MATRIX_PASSWORD=
MATRIX_ACCESS_TOKEN=
MATRIX_ROOM_ID=

# Firebase Client & Admin Configuration
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_DATABASE_URL=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Optional AI Studio / Gemini Credentials
GEMINI_API_KEY=
APP_URL=

# Backblaze B2 Multi-Account Configuration
# Must be a valid JSON array of objects with keys: email, bucket, keyId, appKey, endpoint, region
B2_ACCOUNTS_JSON=

